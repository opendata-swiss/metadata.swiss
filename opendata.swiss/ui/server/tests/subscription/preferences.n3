PREFIX log: <http://www.w3.org/2000/10/swap/log#>
PREFIX string: <http://www.w3.org/2000/10/swap/string#>
PREFIX tuner: <https://api-tuner.described.at/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX earl: <http://www.w3.org/ns/earl#>
PREFIX resource: <https://api-tuner.described.at/resource#>
prefix math: <http://www.w3.org/2000/10/swap/math#>

<#getSubscriptionPreferences>
  a earl:TestCase ;
  <#get> [
    a tuner:Request ;
    tuner:url </api/subscription/preferences> ;
    tuner:method "GET" ;
    tuner:query ( "id" "1" ) ;
    tuner:query ( "token" "41e0a9448f91edba4b05c6c2fc0edb1d6418aa292b5b2942637bec43a29b9523" ) ;
  ] ;
  tuner:formula {
    <#getSubscriptionPreferences> <#get> ?req .
    ?req tuner:response ?res .
    ?res tuner:http_code 200 .

    ?res tuner:jsonPath ( "$.preferences" ?preferences ) .
    {
      ?preferences string:length ?length .
      ?length math:greaterThan 0 .
    }!tuner:assertThat
 } .

<#updateSubscriptionPreferences>
  a earl:TestCase ;
  <#put> [
    a tuner:Request ;
    tuner:url </api/subscription/preferences> ;
    tuner:method "PUT" ;
    tuner:query ( "id" "1" ) ;
    tuner:query ( "token" "41e0a9448f91edba4b05c6c2fc0edb1d6418aa292b5b2942637bec43a29b9523" ) ;
    tuner:form ( "dataset" "dataset1" ) ;
    tuner:form ( "category" "GOVE" ) ;
    tuner:form ( "category" "INTR" ) ;
  ] ;
  <#get> [
    a tuner:Request ;
    tuner:url </api/subscription/preferences> ;
    tuner:method "GET" ;
    tuner:query ( "id" "1" ) ;
    tuner:query ( "token" "41e0a9448f91edba4b05c6c2fc0edb1d6418aa292b5b2942637bec43a29b9523" ) ;
  ] ;
  tuner:formula {
    <#updateSubscriptionPreferences> <#put> ?updateReq .
    ?updateReq tuner:response ?updateRes .
    ?updateRes tuner:http_code 204 .

    <#updateSubscriptionPreferences> <#get> ?req .
    ?req tuner:response ?res .
    ?res tuner:http_code 200 .

    ?res tuner:jsonPath ( "$.preferences.datasets" "dataset1" string:contains ) .
    ?res tuner:jsonPath ( "$.preferences.categories" "GOVE" string:contains ) .
    ?res tuner:jsonPath ( "$.preferences.categories" "INTR" string:contains ) .
 } ;
.
