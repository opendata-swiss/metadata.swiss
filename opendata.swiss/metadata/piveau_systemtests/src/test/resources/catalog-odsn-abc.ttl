@prefix dcat:   <http://www.w3.org/ns/dcat#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix gsp: <http://www.opengis.net/ont/geosparql#> .

<https://data.example.org/id/catalogue/abc>
    a dcat:Catalog ;

    dct:title "%s"@en ,
              "Offene Daten ABC"@de ,
              "Données ouvertes ABC"@fr ,
              "Dati aperti ABC"@it ;

    dct:description "Datenkatalog ABC"@de ,
                    "Data Catalog ABC"@en ,
                    "Catalogue de données ABC"@fr ,
                    "Catalogo dati ABC"@it ;

    dct:publisher <https://data.example.org/org/abc> ;

    dct:language <http://publications.europa.eu/resource/authority/language/DEU> ,
                <http://publications.europa.eu/resource/authority/language/FRA> ,
                <http://publications.europa.eu/resource/authority/language/ITA>,
                <http://publications.europa.eu/resource/authority/language/ENG> ;
    dct:license <http://dcat-ap.ch/vocabulary/licenses/terms_open> ;

    dct:issued "2021-01-07T00:00:00"^^xsd:dateTime ;
    dct:modified "2021-01-07T00:00:00"^^xsd:dateTime .

<https://data.example.org/org/abc>
  a foaf:Organization ;

  foaf:name "Verein ABC"@de ,
            "Association ABC"@fr ,
            "Associazione ABC"@it ,
            "Association ABC"@en .