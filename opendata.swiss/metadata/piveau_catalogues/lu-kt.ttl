<https://example.eu/id/catalogue/lu-kt> a dcat:Catalog ;
    dcterms:created "2023-04-23T20:04:21.644229"^^xsd:dateTime ;
    dcterms:description "Der Kanton Luzern veröffentlicht hier schrittweise geeignete Datensammlungen der kantonalen Verwaltung als OGD-Daten."@de,
        "The Canton of Lucerne is gradually publishing here suitable datasets from the cantonal administration as OGD data."@en,
        "Le canton de Lucerne publie ici progressivement des jeux de données appropriées de l'administration cantonale sous forme de données OGD."@fr,
        "Il cantone di Lucerna sta gradualmente pubblicando qui oportuni set di dati dell'amministrazione cantonale come dati OGD."@it ;
    dcterms:modified "2026-07-20T10:46:47.355000"^^xsd:dateTime ;
    dcterms:publisher [ a foaf:Agent ;
            foaf:homepage <https://www.lu.ch/> ;
            foaf:name "Kanton Luzern"@de,
                "Canton of Lucerne"@en,
                "Canton de Lucerne"@fr,
                "Cantone di Lucerna"@it ] ;
    dcterms:spatial <http://publications.europa.eu/resource/authority/country/CHE> ;
    dcterms:title "Kanton Luzern"@de,
        "Canton of Lucerne"@en,
        "Canton de Lucerne"@fr,
        "Cantone di Lucerna"@it ;
    dcterms:type "ckan"^^xsd:string .

